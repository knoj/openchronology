        "science",
        "united-states",
        "1000-year-project"
      ],
      "translations": {
        "fr": {
          "title": "Apollo 11 — Premier alunissage habité",
          "description": "Le 20 juillet 1969 à 20h17 UTC, Neil Armstrong et Buzz Aldrin posent le module lunaire Eagle sur la Mer de la Tranquillité, devenant les premiers êtres humains à marcher sur la Lune.",
          "date_label": "20 juillet 1969"
        }
      }
